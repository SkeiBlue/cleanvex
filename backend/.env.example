# ── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@POSTGRES_HOST:5432/pj?schema=public"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-with-a-long-random-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_DAYS="14"

# ── CORS / URLs ───────────────────────────────────────────────────────────────
FRONTEND_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"
APP_PUBLIC_URL="http://localhost:5173"

# ── Fichiers privés ───────────────────────────────────────────────────────────
PRIVATE_FILES_DIR="../private-files"

# ── Inscription (laisser vide pour désactiver le code d'invitation) ───────────
SIGNUP_INVITE_CODE=""

# ── SMTP (laisser vide pour désactiver les emails) ───────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Personal Platform <no-reply@example.local>"

# ── Adresse destinataire du formulaire Contact (landing) ─────────────────────
# Si vide, retombe sur MAIL_FROM. Mettre ton vrai email pour recevoir les messages.
CONTACT_EMAIL=""

# ── Module cache TTL (secondes, défaut : 30) ─────────────────────────────────
# MODULE_CACHE_TTL_SECONDS="30"
