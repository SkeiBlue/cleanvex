// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  username        String?
  passwordHash    String    @map("password_hash")
  role            String    @default("user")
  isActive        Boolean   @default(true) @map("is_active")
  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")
  lastLoginAt     DateTime? @map("last_login_at")
  totpSecret      String?   @map("totp_secret")
  totpEnabled     Boolean   @default(false) @map("totp_enabled")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  documents          Document[]
  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  settings      UserSetting[]
  auditLogs     AuditLog[]
  activityLogs  ActivityLog[]
  financialAccounts     FinancialAccount[]
  financialCategories   FinancialCategory[]
  financialTransactions FinancialTransaction[]
  stockItems            StockItem[]
  stockMovements        StockMovement[]
  toolLoans             ToolLoan[]
  vehicles              Vehicle[]
  properties            Property[]
  contacts              Contact[]
  tasks                 Task[]
  notifications         Notification[]

  @@map("users")
}

model RefreshToken {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  tokenHash         String    @map("token_hash")
  deviceName        String?   @map("device_name")
  ipAddress         String?   @map("ip_address")
  userAgent         String?   @map("user_agent")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  lastUsedAt        DateTime? @map("last_used_at")
  replacedByTokenId String?   @map("replaced_by_token_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tokenHash   String    @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  resendCount Int       @default(0) @map("resend_count")

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Module {
  id        String   @id @default(uuid())
  key       String   @unique
  title     String
  version   String
  isEnabled Boolean  @default(true) @map("is_enabled")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("modules")
}

model UserSetting {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  key       String
  valueJson Json     @map("value_json")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("user_settings")
}

model Document {
  id          String   @id @default(uuid())
  ownerId     String   @map("owner_id")
  name        String
  type        String
  visibility  String   @default("private")
  storagePath String   @map("storage_path")
  mimeType    String   @map("mime_type")
  size        Int
  hash        String
  tagsJson    Json?    @map("tags_json")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  links DocumentLink[]

  @@index([ownerId])
  @@map("documents")
}

model DocumentLink {
  id         String   @id @default(uuid())
  documentId String   @map("document_id")
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  context    String?
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@map("document_links")
}

model DocumentCategory {
  id        String  @id @default(uuid())
  name      String
  moduleKey String? @map("module_key")
  color     String?

  @@map("document_categories")
}

model Vehicle {
  id              String    @id @default(uuid())
  ownerId         String?   @map("owner_id")
  name            String
  type            String
  status          String
  brand           String?
  model           String?
  year            Int?
  registration    String?
  vin             String?
  mileage         Int       @default(0)
  fuelType        String?   @map("fuel_type")
  color           String?
  power           Int?
  purchaseDate    DateTime? @map("purchase_date")
  purchasePrice   Decimal?  @map("purchase_price") @db.Decimal(12, 2)
  insuranceExpiry DateTime? @map("insurance_expiry")
  ctExpiry        DateTime? @map("ct_expiry")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  owner         User?                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  mileageLogs   VehicleMileageLog[]
  interventions VehicleIntervention[]
  alerts        VehicleAlert[]
  parts         VehiclePart[]

  @@index([ownerId])
  @@map("vehicles")
}

model VehiclePart {
  id             String   @id @default(uuid())
  vehicleId      String   @map("vehicle_id")
  name           String
  quantity       Int      @default(1)
  category       String   @default("autre")
  status         String   @default("a-acheter")
  urgency        String   @default("normal")
  priority       String   @default("fiabilite")
  reference      String?
  dimension      String?
  estimatedPrice Decimal? @map("estimated_price") @db.Decimal(12, 2)
  realPrice      Decimal? @map("real_price") @db.Decimal(12, 2)
  link           String?
  comment        String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_parts")
}

model VehicleMileageLog {
  id         String   @id @default(uuid())
  vehicleId  String   @map("vehicle_id")
  mileage    Int
  date       DateTime
  sourceType String?  @map("source_type")
  sourceId   String?  @map("source_id")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_mileage_logs")
}

model VehicleIntervention {
  id          String   @id @default(uuid())
  vehicleId   String   @map("vehicle_id")
  title       String
  date        DateTime
  mileage     Int?
  timeMinutes Int?     @map("time_minutes")
  costAmount  Decimal? @map("cost_amount") @db.Decimal(12, 2)
  status      String   @default("planned")
  // 'self' = fait moi-même (défaut). 'pro' = délégué à un professionnel
  // (atelier, garagiste, concessionnaire…). Utilisé pour le carnet
  // d'entretien et les filtres associés.
  executor         String  @default("self")
  professionalName String? @map("professional_name")
  notes       String?

  // Lot A — Interventions enrichies.
  // category : type de travail (vidange, freinage, pneus, distribution…),
  // chaîne ouverte (pas un enum) pour rester souple.
  category String?
  // Garantie de l'intervention/pièce : échéance par date ET/OU kilométrage.
  warrantyUntil   DateTime? @map("warranty_until")
  warrantyMileage Int?      @map("warranty_mileage")
  // Prochaine échéance liée (ex: prochaine vidange) par date ET/OU km.
  nextDueDate    DateTime? @map("next_due_date")
  nextDueMileage Int?      @map("next_due_mileage")

  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@index([vehicleId])
  @@map("vehicle_interventions")
}

model VehicleAlert {
  id        String    @id @default(uuid())
  vehicleId String    @map("vehicle_id")
  type      String
  title     String
  dueDate   DateTime? @map("due_date")
  status    String    @default("open")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_alerts")
}

model Property {
  id             String   @id @default(uuid())
  ownerId        String   @map("owner_id")
  name           String
  type           String
  status         String
  address        String?
  city           String?
  postalCode     String?  @map("postal_code")
  country        String   @default("FR")
  surface        Decimal? @db.Decimal(10, 2)
  rooms          Int?
  purchasePrice  Decimal? @map("purchase_price") @db.Decimal(12, 2)
  estimatedValue Decimal? @map("estimated_value") @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  owner  User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  events PropertyEvent[]

  @@index([ownerId])
  @@map("properties")
}

model PropertyEvent {
  id         String    @id @default(uuid())
  propertyId String    @map("property_id")
  type       String
  title      String
  date       DateTime
  amount     Decimal?  @db.Decimal(12, 2)
  status     String    @default("planned")
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_events")
}

model Contact {
  id           String   @id @default(uuid())
  ownerId      String   @map("owner_id")
  kind         String   @default("person")
  displayName  String   @map("display_name")
  organization String?
  email        String?
  phone        String?
  address      String?
  city         String?
  postalCode   String?  @map("postal_code")
  country      String   @default("FR")
  tagsJson     Json?    @map("tags_json")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  owner        User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  interactions ContactInteraction[]

  @@index([ownerId])
  @@map("contacts")
}

model ContactInteraction {
  id        String   @id @default(uuid())
  contactId String   @map("contact_id")
  type      String
  title     String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_interactions")
}

model FinancialAccount {
  id             String   @id @default(uuid())
  ownerId        String   @map("owner_id")
  name           String
  type           String
  currency       String   @default("EUR")
  initialBalance Decimal  @default(0) @map("initial_balance") @db.Decimal(12, 2)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  owner        User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@index([ownerId])
  @@map("financial_accounts")
}

model FinancialCategory {
  id       String  @id @default(uuid())
  ownerId  String  @map("owner_id")
  name     String
  type     String
  parentId String? @map("parent_id")
  color    String?

  owner        User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@index([ownerId])
  @@map("financial_categories")
}

model FinancialTransaction {
  id            String   @id @default(uuid())
  ownerId       String   @map("owner_id")
  type          String
  amount        Decimal  @db.Decimal(12, 2)
  accountId     String   @map("account_id")
  categoryId    String?  @map("category_id")
  operationDate DateTime @map("operation_date")
  label         String
  note          String?
  sourceModule  String?  @map("source_module")
  sourceType    String?  @map("source_type")
  sourceId      String?  @map("source_id")
  status        String   @default("manual")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  owner    User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  account  FinancialAccount   @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category FinancialCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([ownerId, operationDate(sort: Desc)])
  @@index([sourceModule, sourceType, sourceId])
  @@map("financial_transactions")
}

model StockItem {
  id               String   @id @default(uuid())
  ownerId          String   @map("owner_id")
  name             String
  category         String
  unit             String
  quantity         Decimal  @default(0) @db.Decimal(12, 2)
  // 'in-stock' = article disponible normalement. 'to-buy' = article que l'on
  // souhaite acheter prochainement (wishlist d'achat). Pas un enum pour
  // rester ouvert si on ajoute d'autres états plus tard.
  status           String   @default("in-stock")
  thresholdEnabled Boolean  @default(false) @map("threshold_enabled")
  threshold        Decimal? @db.Decimal(12, 2)
  location         String?
  valueAmount      Decimal? @map("value_amount") @db.Decimal(12, 2)
  reference        String?
  supplier         String?
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  owner     User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  movements StockMovement[]
  loans     ToolLoan[]

  @@index([ownerId])
  @@map("stock_items")
}

model ToolLoan {
  id                 String    @id @default(uuid())
  ownerId            String    @map("owner_id")
  stockItemId        String    @map("stock_item_id")
  borrowerName       String    @map("borrower_name")
  loanDate           DateTime  @map("loan_date")
  expectedReturnDate DateTime? @map("expected_return_date")
  returnedAt         DateTime? @map("returned_at")
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("tool_loans")
}

model StockMovement {
  id          String   @id @default(uuid())
  ownerId     String   @map("owner_id")
  stockItemId String   @map("stock_item_id")
  type        String
  quantity    Decimal  @db.Decimal(12, 2)
  valueAmount Decimal? @map("value_amount") @db.Decimal(12, 2)
  sourceType  String?  @map("source_type")
  sourceId    String?  @map("source_id")
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  // Lien fin vers une intervention véhicule précise quand le mouvement a
  // été déclenché par la création/validation d'un travail (S2). Permet
  // d'afficher dans la fiche véhicule la liste des pièces consommées par
  // intervention plutôt qu'agrégées au niveau véhicule.
  interventionId String? @map("intervention_id")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  owner        User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  stockItem    StockItem            @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  intervention VehicleIntervention? @relation(fields: [interventionId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([targetType, targetId])
  @@index([interventionId])
  @@map("stock_movements")
}

model Task {
  id          String    @id @default(uuid())
  ownerId     String    @map("owner_id")
  title       String
  description String?
  status      String    @default("open")
  priority    String    @default("normal")
  dueDate     DateTime? @map("due_date")
  moduleKey   String?   @map("module_key")
  targetType  String?   @map("target_type")
  targetId    String?   @map("target_id")
  progress    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  subtasks Subtask[]

  @@index([ownerId])
  @@index([targetType, targetId])
  @@map("tasks")
}

model Subtask {
  id       String  @id @default(uuid())
  taskId   String  @map("task_id")
  title    String
  isDone   Boolean @default(false) @map("is_done")
  position Int     @default(0)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("subtasks")
}

model Notification {
  id         String    @id @default(uuid())
  ownerId    String    @map("owner_id")
  type       String
  title      String
  message    String?
  importance String    @default("normal")
  dueDate    DateTime? @map("due_date")
  targetType String?   @map("target_type")
  targetId   String?   @map("target_id")
  isRead     Boolean   @default(false) @map("is_read")
  createdAt  DateTime  @default(now()) @map("created_at")

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([ownerId, isRead])
  @@index([targetType, targetId])
  @@map("notifications")
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  action       String
  targetType   String?  @map("target_type")
  targetId     String?  @map("target_id")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  moduleKey  String?  @map("module_key")
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([moduleKey])
  @@map("activity_logs")
}

model ErrorLog {
  id          String   @id @default(uuid())
  level       String
  message     String
  contextJson Json?    @map("context_json")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("error_logs")
}
